{
    "version": 8,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 18,
        "patch": 0
      },
  "configurePresets": [
    {
      "name": "rocm",
      "description": "Build with ROCm",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "BUILD_TYPE": "Release",
        "CMAKE_BUILD_TYPE": "Release",
        "USE_HIP": "ON",
        "GPU_TARGETS": "gfx90a,gfx942",
        "ROCM_TARGET_ARCH": "gfx90a,gfx942",
        "CMAKE_HIP_ARCHITECTURES": "gfx90a,gfx942",
        "CMAKE_INSTALL_PREFIX": "/opt/rocm",
        "BUILD_CPP_TEST": "ON",
        "CMAKE_C_FLAGS": "-fdiagnostics-color=always",
        "CMAKE_CXX_FLAGS": "-fdiagnostics-color=always",
        "CMAKE_HIP_FLAGS": "-ftime-trace -fdiagnostics-color=always",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_PREFIX_PATH": "/opt/rocm/lib/cmake",
        "CMAKE_COLOR_DIAGNOSTICS": "ON"
      }
    },
    {
      "name": "rocm-llvm",
      "description": "Build with ROCm and LLVM for host compiler",
      "inherits": ["rocm"],
      "cacheVariables": {
        "CMAKE_C_COMPILER":"clang",
        "CMAKE_CXX_COMPILER":"clang++",
        "CMAKE_C_FLAGS": "-ftime-trace",
        "CMAKE_CXX_FLAGS": "-ftime-trace"
      }
    }
  ]
}
