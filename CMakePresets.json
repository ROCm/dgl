{
    "version": 7,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 18,
        "patch": 0
      },
  "configurePresets": [
    {
      "name": "rocm",
      "description": "Build with ROCm",
      "generator": "Ninja",
      "binaryDir": "$env{DGL_BUILD_DIR}",
      "cacheVariables": {
        "BUILD_TYPE": "Release",
        "CMAKE_BUILD_TYPE": "Release",
        "USE_HIP": "ON",
        "GPU_TARGETS": "$env{ROCM_GPU_TARGETS}",
        "CMAKE_HIP_ARCHITECTURES": "$env{ROCM_GPU_TARGETS}",
        "CMAKE_INSTALL_PREFIX": "$env{ROCM_HOME}",
        "BUILD_CPP_TEST": "ON",
        "CMAKE_C_FLAGS": "-fdiagnostics-color=always",
        "CMAKE_CXX_FLAGS": "-fdiagnostics-color=always",
        "CMAKE_HIP_FLAGS": "-ftime-trace -fdiagnostics-color=always",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_PREFIX_PATH": "$env{ROCM_CMAKE_PATH}",
        "CMAKE_COLOR_DIAGNOSTICS": "ON",
        "CMAKE_HIP_PLATFORM": "$env{ROCM_HIP_PLATFORM}",
        "CMAKE_HIP_COMPILER": "$env{ROCM_CXX_PATH}",
        "CMAKE_HIP_COMPILER_ROCM_ROOT": "$env{ROCM_HOME}",
        "TORCH_PYTHON_INTERPS": "$env{ROCK_PYTHON_INTERPRETER}"
      }
    },
    {
      "name": "rocm-llvm",
      "description": "Build with ROCm and LLVM for host compiler",
      "inherits": ["rocm"],
      "cacheVariables": {
        "CMAKE_C_COMPILER":"$env{ROCM_CC_PATH}",
        "CMAKE_CXX_COMPILER":"$env{ROCM_CXX_PATH}",
        "CMAKE_C_FLAGS": "-ftime-trace",
        "CMAKE_CXX_FLAGS": "-ftime-trace"
      }
    },  
    {
      "name": "rocm-cov",
      "description": "Build with ROCm and llvm-cov for code coverage",
      "inherits": ["rocm-llvm"],
      "cacheVariables": {
        "BUILD_TYPE": "Debug",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS":   "-O0 -g3 -ggdb -fprofile-instr-generate -fcoverage-mapping -Wl,--allow-multiple-definition",
        "CMAKE_CXX_FLAGS": "-O0 -g3 -ggdb -fprofile-instr-generate -fcoverage-mapping -Wl,--allow-multiple-definition",
        "CMAKE_HIP_FLAGS": "-O0 -g3 -ggdb -fprofile-instr-generate -fcoverage-mapping -Wl,--allow-multiple-definition"
      }
    }
  ]
}
