# We ignore things to reduce the size of the context, but also to minimize cache
# invalidations. This isn't comprehensive but knocks out a good chunk of
# potential invalidations and big files.

# Submodules we don't use for ROCm. Since the ROCm image is the only one that
# uses the repository as context, exclude these.
third_party/cccl/
third_party/libxsmm/
third_party/cuco

# We just need the work tree, not the whole git history
**/*.git/

# These top-level directories don't affect the build
.github/
apps/
benchmarks/
conda/
dglgo/
docs/
examples/
notebooks/
# We don't exclude tests/ because it's not super big and it's nice to be able to
# run tests in the built image
tools/
tutorials/

# These third_party/ directories don't affect the build
**/.github/
**/docs/
**/examples/
**/doxygen/
third_party/taskflow/image/
third_party/taskflow/tfprof/
third_party/taskflow/benchmarks/

# These file types don't affect the build
**/Jenkinsfile
**/*.md
**/.gitignore
**/readthedocs.yml
**/*.pdf
**/*.prehip

# Changing the dockerignore might change the context itself, but no-op changes
# to it shouldn't invalidate the cache.
**/.dockerignore

# As long as the docker images are linux-only, we can ignore windows files
**/*.bat

# The affect of the Dockerfile itself on the cache is already captured. Don't
# let changes to the file invalidate the whole copy cache.
**/Dockerfile.*


# The rest is a copy of the .gitignore file except that .dockignore has annoying
# syntax differences with .gitignore: Bare filenames are always taken relative
# to the .dockerignore file, not applied everywhere. So if you want to ignore
# files by extension, you have to do **/*.md instead of just *.md

# IDE
.idea

# Byte-compiled / optimized / DLL files
__pycache__/
**/*.py[cod]
**/*$py.class

# C extensions
**/*.so

# Distribution / packaging
.Python
**/build
**/build-*/
**/out/
**/CMakeUserPresets.json
**/dataset/
**/datasets/
**/develop-eggs/
**/dist/
**/downloads/
**/eggs/
**/.eggs/
**/lib/
**/lib64/
**/parts/
**/sdist/
**/var/
**/wheels/
**/*.egg-info/
**/*.installed.cfg
**/*.egg
**/MANIFEST

# Whitelist some distribution / package non-related directories
!tests/dist

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
**/*.manifest
**/*.spec

# For the dockerignore, which applies third_party/ also, we need the
# liburing.spec file
!**/third_party/liburing/**/*.spec

# Installer logs
**/pip-log.txt
**/pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
**/*.tox/
**/*.coverage
**/*.coverage.*
**/*.cache
nosetests.xml
coverage.xml
**/*.cover
**/*.hypothesis/
**/*.pytest_cache/

# Translations
**/*.mo
**/*.pot

# Django stuff:
**/*.log
**/local_settings.py
**/db.sqlite3

# Flask stuff:
instance/
**/*.webassets-cache

# Scrapy stuff:
**/*.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
**/*.ipynb_checkpoints

# pyenv
**/*.python-version

# celery beat schedule file
**/celerybeat-schedule

# SageMath parsed files
**/*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/

# The specific examples/ file deleted from the dockerignore because the whole
# directory is already excluded
**/*.DS_Store

# data directory
_download

# CTags & CScope
tags
cscope.*

# Vim
**/*.swp
**/*.swo
**/*.un~
*~

# parameters
**/*.params

# vscode
.clangd
.vscode
**/*.code-workspace

# asv
**/*.asv

**/*.ycm_extra_conf.py
**/*.png

# model file
**/*.pth
